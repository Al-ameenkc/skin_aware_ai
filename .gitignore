# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Documentation, thesis, and research materials (not part of the web app)
/docs/
/documentation/
/screenshots/
/docs-screenshots/
*.docx
*.doc
*.pdf
*_extract.txt
_ekene_extract.txt
EKENE.docx
EKENE1.docx

# Documentation images (keep public/ web assets tracked)
/docs/**/*.png
/docs/**/*.jpg
/docs/**/*.jpeg
/docs/**/*.gif
/docs/**/*.webp
/screenshots/**/*.png
/screenshots/**/*.jpg
/screenshots/**/*.jpeg
/screenshots/**/*.gif
/screenshots/**/*.webp
/docs-screenshots/**
